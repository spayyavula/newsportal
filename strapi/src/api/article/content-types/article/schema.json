{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article",
    "description": "Editorial stories for the news portal"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "summary": {
      "type": "text",
      "required": true
    },
    "readTime": {
      "type": "string",
      "required": true
    },
    "storyType": {
      "type": "enumeration",
      "enum": ["reporting", "analysis", "opinion"],
      "required": true
    },
    "body": {
      "type": "richtext",
      "required": true
    },
    "contentBlocks": {
      "type": "dynamiczone",
      "components": [
        "editorial.section-block",
        "editorial.pull-quote",
        "editorial.explainer"
      ]
    },
    "sources": {
      "type": "json",
      "required": true
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "required": true
    },
    "publishedOn": {
      "type": "datetime",
      "required": true
    },
    "author": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::author.author",
      "inversedBy": "articles"
    },
    "topic": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::topic.topic",
      "inversedBy": "articles"
    },
    "views": {
      "type": "integer",
      "default": 0
    },
    "tips": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::tip.tip",
      "mappedBy": "article"
    }
  }
}