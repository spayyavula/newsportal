{
  "kind": "collectionType",
  "collectionName": "authors",
  "info": {
    "singularName": "author",
    "pluralName": "authors",
    "displayName": "Author",
    "description": "Writer profiles for the newsroom"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "role": {
      "type": "string",
      "required": true
    },
    "bio": {
      "type": "text",
      "required": true
    },
    "credentials": {
      "type": "text",
      "required": true
    },
    "coverageAreas": {
      "type": "json",
      "required": true
    },
    "editorialPrinciples": {
      "type": "json",
      "required": true
    },
    "contactNote": {
      "type": "text",
      "required": true
    },
    "articles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::article.article",
      "mappedBy": "author"
    },
    "earnings": {
      "type": "decimal",
      "default": 0
    },
    "tips": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::tip.tip",
      "mappedBy": "author"
    }
  }
}